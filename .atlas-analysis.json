  "keyFeatures": [
    "Generate expiring viewer links to private GitHub repositories",
    "Allow recruiters to browse code without GitHub login",
    "Read-only access with no forking or editing capabilities",
    "Track view limits and expiration per link",
    "Developer dashboard to manage viewer links",
    "GitHub OAuth2 authentication with JWT-style token auth"
  ],
  "publicApiSurface": [
    "GET /github/login",
    "GET /github/callback",
    "GET /me",
    "GET /dashboard",
    "POST /generate-viewer-link",
    "PUT /update-link/:id",
    "DELETE /delete-link/:id",
    "GET /view/:token",
    "GET /view-files/:token/file",
    "GET /view-folder/:token",
    "GET /view-info/:token"
  ]
